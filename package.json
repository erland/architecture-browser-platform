{
  "name": "architecture-browser-platform",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/web",
    "libs/contracts",
    "libs/view-models"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace @architecture-browser-platform/web",
    "build:web": "npm run build --workspace @architecture-browser-platform/web",
    "lint:web": "npm run lint --workspace @architecture-browser-platform/web",
    "typecheck:web": "npm run typecheck --workspace @architecture-browser-platform/web",
    "test:web": "npm run test --workspace @architecture-browser-platform/web",
    "dev:stack": "docker compose -f deploy/docker-compose/docker-compose.dev.yml up --build",
    "dev:stack:down": "docker compose -f deploy/docker-compose/docker-compose.dev.yml down",
    "test:stack": "docker compose --env-file deploy/env/platform-test.env -f deploy/docker-compose/docker-compose.test.yml up -d",
    "test:stack:down": "docker compose --env-file deploy/env/platform-test.env -f deploy/docker-compose/docker-compose.test.yml down",
    "smoke:test": "./scripts/smoke-test.sh",
    "verify:safety-net": "./scripts/verify-safety-net.sh",
    "clean:generated": "./scripts/clean-generated-artifacts.sh",
    "verify:refactor": "./scripts/verify-refactor.sh",
    "verify:browser-only-baseline": "./scripts/verify-browser-only-baseline.sh"
  }
}
