            "integer",
            "null"
          ]
        },
        "endLine": {
          "type": [
            "integer",
            "null"
          ]
        },
        "snippet": {
          "type": [
            "string",
            "null"
          ]
        },
        "metadata": {
          "$ref": "#/$defs/jsonObject"
        }
