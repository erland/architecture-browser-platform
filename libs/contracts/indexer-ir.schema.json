    "schemaVersion": {
      "type": "string"
    },
    "indexerVersion": {
      "type": "string"
    },
    "runMetadata": {
      "$ref": "#/$defs/runMetadata"
    },
    "source": {
      "$ref": "#/$defs/repositorySource"
    },
    "scopes": {
      "type": "array",
      "items": {
