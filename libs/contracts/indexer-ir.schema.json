        "id",
        "kind",
        "origin",
        "name",
        "displayName",
        "scopeId",
        "sourceRefs",
        "metadata"
      ],
      "properties": {
        "id": {
          "type": "string"
        },
        "kind": {
          "enum": [
            "CLASS",
            "INTERFACE",
            "FUNCTION",
            "FIELD",
            "MODULE",
            "ENDPOINT",
            "SERVICE",
            "PERSISTENCE_ADAPTER",
            "UI_MODULE",
            "STARTUP_POINT",
            "DATASTORE",
            "EXTERNAL_SYSTEM",
            "CONFIG_ARTIFACT"
          ]
        },
        "origin": {
          "enum": [
            "OBSERVED",
            "INFERRED"
          ]
        },
        "name": {
          "type": "string"
        },
        "displayName": {
          "type": "string"
        },
        "scopeId": {
          "type": "string"
        },
        "sourceRefs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/sourceReference"
          }
